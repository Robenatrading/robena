---
import "../styles/global.css";
---

<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Despre noi | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
        <a href="/" aria-label="ROBENA TRADING - Acasă" class="shrink-0">
          <img
            src="/images/logo-robena.png"
            alt="ROBENA TRADING"
            class="h-24 w-auto object-contain md:h-32"
          />
        </a>

        <nav class="hidden items-center gap-8 text-sm font-semibold text-slate-700 md:flex">
          <a class="transition hover:text-blue-700" href="/">Acasă</a>
          <a class="transition hover:text-blue-700" href="/#produse">Produse</a>
          <a class="transition hover:text-blue-700" href="/despre">Despre noi</a>
          <a class="transition hover:text-blue-700" href="/contact">Contact</a>
        </nav>

        <a
          href="/contact"
          class="hidden rounded-lg bg-blue-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-800 md:inline-flex"
        >
          Solicită ofertă
        </a>
      </div>
    </header>

    <main>
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h1 class="text-center text-5xl font-bold text-slate-900">
          Despre noi
        </h1>

        <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-10 shadow">
          <h2 class="text-2xl font-bold">
            ROBENA TRADING
          </h2>

          <p class="mt-8 text-lg leading-8 text-slate-700">
            ROBENA TRADING este o companie românească specializată în furnizarea
            unei game variate de produse și echipamente profesionale pentru
            instituții publice, unități medicale, companii și persoane fizice.
          </p>

          <p class="mt-6 text-lg leading-8 text-slate-700">
            Oferim mobilier medical și metalic, mobilier de birou, aparatură,
            echipamente, textile, consumabile și numeroase alte produse
            profesionale, colaborând cu producători și furnizori de încredere
            pentru a răspunde celor mai exigente cerințe.
          </p>

          <p class="mt-6 text-lg leading-8 text-slate-700">
            Ne adresăm spitalelor, clinicilor, centrelor medicale,
            instituțiilor publice, școlilor, companiilor, organizațiilor și
            persoanelor fizice din întreaga țară, oferind soluții complete și
            produse de calitate adaptate fiecărui domeniu de activitate.
          </p>

          <p class="mt-6 text-lg leading-8 text-slate-700">
            Obiectivul nostru este construirea unor parteneriate pe termen lung,
            bazate pe seriozitate, profesionalism, promptitudine și respect
            față de client. Punem accent pe calitatea produselor, consultanță
            dedicată și servicii eficiente înainte și după achiziție.
          </p>

          <p class="mt-6 text-lg leading-8 text-slate-700">
            ROBENA TRADING înseamnă încredere, calitate și soluții profesionale
            pentru orice proiect, indiferent de dimensiunea sau domeniul de
            activitate al beneficiarului.
          </p>
        </div>
      </div>
    </main>
  </body>
</html>