---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="Mobilier medical profesional oferit de ROBENA TRADING."
    />

    <title>Mobilier medical | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
   <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">


          <h1 class="mt-4 text-4xl font-bold text-slate-900 md:text-5xl">
            Mobilier medical
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Descoperă gama noastră de mobilier medical pentru spitale,
            clinici, cabinete medicale, centre sociale și alte instituții.
          </p>
        </div>

<div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
<!-- Pat medical -->
<article
  class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
>
  <a
    href="/produse/mobilier-medical/pat-medical"
    class="block"
  >
    <div
      class="flex h-72 items-center justify-center overflow-hidden bg-white p-4"
    >
      <img
src="/pat-medical-robena-trading.png"
        alt="Pat medical manual cu 3 secțiuni"
        class="h-full w-full object-contain"
      />
    </div>

    <div class="p-6">
      <h2
        class="text-xl font-bold text-slate-900 hover:text-blue-700"
      >
        Pat medical manual cu 3 secțiuni
      </h2>

      <p class="mt-3 leading-7 text-slate-600">
        Pat medical profesional pentru spitale, clinici și centre de
        îngrijire, prevăzut cu structură metalică rezistentă și funcții
        manuale de reglare.
      </p>
    </div>
  </a>

  <div class="px-6 pb-6">
    <a
      href="/contact"
      class="inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
    >
      Solicită ofertă
    </a>
  </div>
</article>

          <article
            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
          >
            <div class="flex h-64 items-center justify-center bg-slate-100 p-6">
              <img
                src="/images/noptiera-medicala.jpg"
                alt="Noptieră medicală"
                class="h-full w-full object-contain"
              />
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Noptieră medicală
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Noptieră medicală rezistentă și ușor de întreținut pentru
                saloane.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <article
            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
          >
            <div class="flex h-64 items-center justify-center bg-slate-100 p-6">
              <img
                src="/images/carucior-medical.jpg"
                alt="Cărucior medical"
                class="h-full w-full object-contain"
              />
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Cărucior medical
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Cărucior medical pentru transportul instrumentelor,
                consumabilelor și tratamentelor.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>