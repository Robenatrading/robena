---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta
      name="description"
      content="Consumabile oferite de ROBENA TRADING pentru spitale, instituții publice, unități medicale, școli și alte organizații."
    />

    <title>Consumabile | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
      <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="mt-4 text-4xl font-bold text-slate-900 md:text-5xl">
            Consumabile
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Descoperă gama noastră de consumabile pentru spitale, centre
            medicale, instituții publice, școli, centre sociale și alte
            organizații.
          </p>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Produs 1 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Mănuși de unică folosință
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Mănuși de protecție pentru utilizare medicală, igienică și
                instituțională, disponibile în diferite mărimi și variante.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 2 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Măști de protecție
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Măști de protecție pentru unități medicale, instituții și
                activități care necesită măsuri suplimentare de igienă.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 3 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Aleze absorbante
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Aleze de unică folosință pentru protejarea paturilor,
                saltelelor și suprafețelor utilizate în îngrijirea pacienților.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

        </div>
      </section>
    </main>
  </body>
</html>