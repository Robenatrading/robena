---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="Aparatură medicală pentru spitale, clinici, cabinete medicale, centre de îngrijire și instituții publice, oferită de ROBENA TRADING."
    />

    <title>Aparatură medicală | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
      <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">

        <div class="mx-auto max-w-3xl text-center">
          <h1 class="mt-4 text-4xl font-bold text-slate-900 md:text-5xl">
            Aparatură medicală
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Descoperă gama noastră de aparatură medicală pentru spitale,
            clinici, cabinete medicale, centre de diagnostic și alte instituții
            din domeniul medical.
          </p>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Produs 1 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">
                Imagine produs
              </p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Concentrator de oxigen
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Aparat destinat furnizării oxigenului concentrat pentru
                utilizare medicală în spitale, clinici și la domiciliu.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 2 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">
                Imagine produs
              </p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Aspirator chirurgical
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Echipament medical pentru aspirarea lichidelor în timpul
                procedurilor medicale și chirurgicale.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 3 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">
                Imagine produs
              </p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Monitor pentru pacient
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Monitor medical pentru urmărirea parametrilor vitali ai
                pacientului în spitale, clinici și unități de terapie.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

        </div>
      </section>
    </main>
  </body>
</html>