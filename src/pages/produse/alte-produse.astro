---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta
      name="description"
      content="Alte produse oferite de ROBENA TRADING pentru instituții publice, spitale, școli, centre sociale, companii și alte organizații."
    />

    <title>Alte produse | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
      <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="mt-4 text-4xl font-bold text-slate-900 md:text-5xl">
            Alte produse
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Descoperă și alte produse furnizate de ROBENA TRADING pentru
            instituții publice, spitale, școli, centre sociale, companii și alte
            organizații.
          </p>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Produs 1 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Produse pentru curățenie
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Produse și accesorii pentru curățenie, întreținere și igienizare,
                destinate instituțiilor și spațiilor profesionale.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 2 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Produse pentru bucătărie
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Produse și echipamente auxiliare pentru bucătării profesionale,
                cantine, spitale, școli și centre sociale.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 3 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Produse pentru instituții
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Diverse produse destinate activităților administrative,
                operaționale și logistice din cadrul instituțiilor.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

        </div>
      </section>
    </main>
  </body>
</html>