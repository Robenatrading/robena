---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta
      name="description"
      content="Mobilier de birou oferit de ROBENA TRADING pentru instituții, companii și spații profesionale."
    />

    <title>Mobilier de birou | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
      <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="mt-4 text-4xl font-bold text-slate-900 md:text-5xl">
            Mobilier de birou
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Descoperă gama noastră de mobilier de birou pentru instituții,
            companii, școli, universități și alte spații profesionale.
          </p>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

          <!-- Produs 1 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Birou profesional
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Birou rezistent și configurabil pentru instituții, companii și
                spații administrative.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 2 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Dulap de birou
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Dulap pentru documente și materiale, disponibil în diferite
                dimensiuni și configurații.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 3 -->
          <article
            class="overflow-hidden rounded-2xl bg-white transition hover:-translate-y-1"
          >
            <div class="flex h-72 items-center justify-center bg-slate-100 p-6">
              <p class="text-slate-500">Imagine produs</p>
            </div>

            <div class="p-6">
              <h2 class="text-xl font-bold text-slate-900">
                Scaun de birou
              </h2>

              <p class="mt-3 leading-7 text-slate-600">
                Scaun ergonomic pentru birouri, recepții, săli de ședință și
                spații administrative.
              </p>

              <a
                href="/contact"
                class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

        </div>
      </section>
    </main>
  </body>
</html>