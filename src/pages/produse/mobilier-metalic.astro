---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="Mobilier metalic profesional oferit de ROBENA TRADING."
    />

    <title>Mobilier metalic | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main>
      <section class="mx-auto max-w-7xl px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-bold text-slate-900 md:text-5xl">
            Mobilier metalic
          </h1>

          <p class="mt-4 text-lg leading-8 text-slate-600">
            Descoperă gama noastră de mobilier metalic pentru instituții,
            companii, birouri, vestiare, arhive, spații tehnice și alte
            domenii profesionale.
          </p>
        </div>

        <div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <!-- Produs 1 -->
          <article
            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
          >
            <a href="/produse/mobilier-metalic/dulap-metalic" class="block">
              <div class="h-64 overflow-hidden bg-slate-100">
                <img
                  src="/images/dulap-metalic.jpg"
                  alt="Dulap metalic"
                  class="h-full w-full object-cover"
                />
              </div>

              <div class="p-6">
                <h2 class="text-xl font-bold text-slate-900 hover:text-blue-700">
                  Dulap metalic
                </h2>

                <p class="mt-3 leading-7 text-slate-600">
                  Dulap metalic rezistent, destinat arhivării, depozitării și
                  organizării documentelor sau echipamentelor.
                </p>
              </div>
            </a>

            <div class="px-6 pb-6">
              <a
                href="/contact"
                class="inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 2 -->
          <article
            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
          >
            <a href="/produse/mobilier-metalic/vestiar-metalic" class="block">
              <div class="h-64 overflow-hidden bg-slate-100">
                <img
                  src="/images/vestiar-metalic.jpg"
                  alt="Vestiar metalic"
                  class="h-full w-full object-cover"
                />
              </div>

              <div class="p-6">
                <h2 class="text-xl font-bold text-slate-900 hover:text-blue-700">
                  Vestiar metalic
                </h2>

                <p class="mt-3 leading-7 text-slate-600">
                  Vestiar metalic pentru personal, potrivit instituțiilor,
                  companiilor, fabricilor, școlilor și spațiilor sportive.
                </p>
              </div>
            </a>

            <div class="px-6 pb-6">
              <a
                href="/contact"
                class="inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>

          <!-- Produs 3 -->
          <article
            class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-xl"
          >
            <a href="/produse/mobilier-metalic/raft-metalic" class="block">
              <div class="h-64 overflow-hidden bg-slate-100">
                <img
                  src="/images/raft-metalic.jpg"
                  alt="Raft metalic"
                  class="h-full w-full object-cover"
                />
              </div>

              <div class="p-6">
                <h2 class="text-xl font-bold text-slate-900 hover:text-blue-700">
                  Raft metalic
                </h2>

                <p class="mt-3 leading-7 text-slate-600">
                  Raft metalic modular pentru depozite, arhive, magazii,
                  instituții și spații comerciale.
                </p>
              </div>
            </a>

            <div class="px-6 pb-6">
              <a
                href="/contact"
                class="inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Solicită ofertă
              </a>
            </div>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>