---
import "../../../styles/global.css";
import Header from "../../../components/Header.astro";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Noptieră medicală | ROBENA TRADING</title>

    <meta
      name="description"
      content="Noptieră medicală cu sertar și compartiment inferior pentru spitale, clinici și centre de îngrijire."
    />
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />

    <main class="mx-auto max-w-7xl px-6 pt-8 pb-10">

      <section class="mt-12 grid items-start gap-12 lg:grid-cols-2">

        <div class="flex min-h-[500px] items-center justify-center">
          <img
            src="/images/noptiera-medicala-robena-trading.png"
            alt="Noptieră medicală cu sertar și dulap"
            class="max-h-[500px] w-full object-contain"
          />
        </div>

        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-blue-700">
            Mobilier medical
          </p>

          <h1 class="mt-3 text-4xl font-bold leading-tight text-slate-900 lg:text-5xl">
            Noptieră medicală
          </h1>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            Noptieră medicală practică și rezistentă, prevăzută cu sertar,
            compartiment inferior și suprafață superioară cu margini ridicate.
            Este potrivită pentru saloane de spital, clinici și centre de
            îngrijire.
          </p>

          <p class="mt-4 text-lg leading-8 text-slate-600">
            Permite organizarea obiectelor personale, documentelor,
            consumabilelor și materialelor utilizate de pacient sau de
            personalul medical. Suprafețele sunt ușor de curățat și întreținut.
          </p>

          <a
            href="/contact"
            class="mt-8 inline-flex rounded-lg bg-blue-700 px-8 py-4 text-lg font-semibold text-white transition hover:bg-blue-800"
          >
            Solicită ofertă
          </a>
        </div>

      </section>

      <section class="mt-4 rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-lg">
        <h2 class="text-3xl font-bold text-slate-900 lg:text-4xl">
          NE GĂSIȚI ȘI PE SEAP!
        </h2>

        <p class="mx-auto mt-6 max-w-5xl text-lg leading-8 text-slate-600">
          ROBENA TRADING este furnizor în Sistemul Electronic de Achiziții
          Publice, oferind mobilier medical, mobilier metalic, echipamente,
          textile și consumabile pentru instituții publice din întreaga țară.
        </p>
      </section>

    </main>
  </body>
</html>