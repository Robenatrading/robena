---
import "../styles/global.css";
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <meta
      name="description"
      content="ROBENA TRADING – mobilier medical, mobilier metalic, textile și produse pentru instituții."
    />
    <title>ROBENA TRADING | Mobilier medical și metalic</title>
  </head>

  <body>
<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" aria-label="ROBENA TRADING - Acasă" class="shrink-0">
      <img
        src="/images/logo-robena.png"
        alt="ROBENA TRADING"
        class="h-16 w-auto object-contain md:h-20"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-semibold text-slate-700 md:flex">
      <a class="transition hover:text-blue-700" href="/">Acasă</a>
      <a class="transition hover:text-blue-700" href="#produse">Produse</a>
      <a class="transition hover:text-blue-700" href="#despre">Despre noi</a>
      <a class="transition hover:text-blue-700" href="#contact">Contact</a>
    </nav>

    <a
      href="#contact"
      class="hidden rounded-lg bg-blue-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-800 md:inline-flex"
    >
      Solicită ofertă
    </a>
  </div>
</header>

    <main>
      <section class="bg-slate-50">
        <div
          class="mx-auto grid min-h-[620px] max-w-7xl items-center gap-12 px-6 py-20 lg:grid-cols-2"
        >
          <div>
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">
              ROBENA TRADING
            </p>

            <h1 class="max-w-3xl text-4xl font-bold leading-tight text-slate-900 md:text-6xl">
              Produse și echipamente pentru instituții
            </h1>

            <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
              Mobilier medical, mobilier metalic, textile și produse destinate
              spitalelor, centrelor sociale și instituțiilor publice.
            </p>

            <div class="mt-9 flex flex-wrap gap-4">
              <a
                href="#produse"
                class="rounded-lg bg-blue-700 px-6 py-3 font-semibold text-white transition hover:bg-blue-800"
              >
                Vezi produsele
              </a>

              <a
                href="#contact"
                class="rounded-lg border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-800 transition hover:border-blue-700 hover:text-blue-700"
              >
                Solicită ofertă
              </a>
            </div>
          </div>

          
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-xl">
  <img
    src="/images/hero-robena.png"
    alt="Mobilier medical și produse ROBENA TRADING"
    class="h-[520px] w-full object-cover"
  />
</div>
          </div>
      </section>

<section id="produse" class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-blue-700">
        Categorii de produse
      </p>

      <h2 class="mt-4 text-3xl font-bold text-slate-900 md:text-5xl">
        Soluții pentru instituții și unități medicale
      </h2>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        Catalogul ROBENA va fi organizat pe categorii, iar fiecare produs va
        avea propria pagină cu fotografii, descriere și caracteristici tehnice.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <a
        href="/produse/mobilier-medical"
        class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl"
      >
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">
          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M3 18v-7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v7" />
            <path d="M3 15h18M6 9V6h5a3 3 0 0 1 3 3" />
            <path d="M5 18v2M19 18v2" />
          </svg>
        </div>

        <h3 class="mt-6 text-xl font-bold text-slate-900">
          Mobilier medical
        </h3>

        <p class="mt-3 leading-7 text-slate-600">
          Paturi, noptiere, cărucioare, mese și echipamente pentru spitale.
        </p>

        <span class="mt-6 inline-flex items-center gap-2 font-semibold text-blue-700">
          Vezi produsele
          <span class="transition group-hover:translate-x-1">→</span>
        </span>
      </a>

      <a
        href="/produse/mobilier-metalic"
        class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl"
      >
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">
          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="5" y="3" width="14" height="18" rx="1.5" />
            <path d="M12 3v18M9 8h.01M15 8h.01" />
          </svg>
        </div>

        <h3 class="mt-6 text-xl font-bold text-slate-900">
          Mobilier metalic
        </h3>

        <p class="mt-3 leading-7 text-slate-600">
          Dulapuri, rafturi, vestiare și mobilier metalic pentru instituții.
        </p>

        <span class="mt-6 inline-flex items-center gap-2 font-semibold text-blue-700">
          Vezi produsele
          <span class="transition group-hover:translate-x-1">→</span>
        </span>
      </a>

      <a
        href="/produse/textile"
        class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl"
      >
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">
          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="m4 8 8-4 8 4-8 4-8-4Z" />
            <path d="m4 12 8 4 8-4M4 16l8 4 8-4" />
          </svg>
        </div>

        <h3 class="mt-6 text-xl font-bold text-slate-900">
          Textile
        </h3>

        <p class="mt-3 leading-7 text-slate-600">
          Lenjerii, saltele, perne, uniforme și produse textile.
        </p>

        <span class="mt-6 inline-flex items-center gap-2 font-semibold text-blue-700">
          Vezi produsele
          <span class="transition group-hover:translate-x-1">→</span>
        </span>
      </a>

      <a
        href="/produse/consumabile"
        class="group rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-blue-300 hover:shadow-xl"
      >
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">
          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="m4 7 8-4 8 4-8 4-8-4Z" />
            <path d="M4 7v10l8 4 8-4V7M12 11v10" />
          </svg>
        </div>

        <h3 class="mt-6 text-xl font-bold text-slate-900">
          Consumabile
        </h3>

        <p class="mt-3 leading-7 text-slate-600">
          Produse și accesorii pentru utilizare medicală și instituțională.
        </p>

        <span class="mt-6 inline-flex items-center gap-2 font-semibold text-blue-700">
          Vezi produsele
          <span class="transition group-hover:translate-x-1">→</span>
        </span>
      </a>
    </div>
  </div>
</section>

      <section id="despre" class="bg-slate-900 text-white">
        <div class="mx-auto max-w-7xl px-6 py-20">
          <h2 class="text-3xl font-bold">Despre ROBENA TRADING</h2>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            ROBENA TRADING furnizează produse și echipamente pentru instituții,
            cu accent pe mobilier medical, mobilier metalic, textile și
            soluții adaptate cerințelor beneficiarilor.
          </p>
        </div>
      </section>
    </main>

    <footer id="contact" class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-12">
        <p class="font-semibold text-slate-900">ROBENA TRADING</p>
        <p class="mt-2 text-slate-600">
          Datele complete de contact vor fi introduse aici.
        </p>
      </div>
    </footer>
  </body>
</html>