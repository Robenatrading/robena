---
import "../styles/global.css";
---

<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact | ROBENA TRADING</title>
  </head>

  <body class="bg-slate-50">
    <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
        <a href="/" aria-label="ROBENA TRADING - Acasă" class="shrink-0">
          <img
            src="/images/logo-robena.png"
            alt="ROBENA TRADING"
            class="h-24 w-auto object-contain md:h-32"
          />
        </a>

        <nav class="hidden items-center gap-8 text-sm font-semibold text-slate-700 md:flex">
          <a class="transition hover:text-blue-700" href="/">Acasă</a>
          <a class="transition hover:text-blue-700" href="/#produse">Produse</a>
          <a class="transition hover:text-blue-700" href="/#despre">Despre noi</a>
          <a class="transition hover:text-blue-700" href="/contact">Contact</a>
        </nav>

        <a
          href="/contact"
          class="hidden rounded-lg bg-blue-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-800 md:inline-flex"
        >
          Solicită ofertă
        </a>
      </div>
    </header>

    <main>
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h1 class="text-center text-5xl font-bold text-slate-900">
          Contact
        </h1>

        <div class="mt-16 rounded-3xl border border-slate-200 bg-white p-10 shadow">
          <h2 class="text-2xl font-bold">
            ROBENA TRADING
          </h2>

          <p class="mt-10 text-xl">
            <strong>Telefon:</strong><br />
            <a href="tel:+40740413699" class="text-blue-700 hover:underline">
              0740 413 699
            </a>
          </p>

          <p class="mt-8 text-xl">
            <strong>Email:</strong><br />
            <a href="mailto:robena.trading@yahoo.com" class="text-blue-700 hover:underline">
              robena.trading@yahoo.com
            </a>
          </p>
        </div>
      </div>
    </main>
  </body>
</html>